```gitignore
# Dependencies
node_modules/

# Build artifacts
dist/
build/
*.js
*.ts
*.tsx

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Logs and temp files
*.log
*.tmp
*.swp

# Python related (if any Python files exist in project)
__pycache__/
*.pyc
*.pyo
*.pyd

# Coverage reports
coverage/
htmlcov/
.coverage

# OS generated files
.DS_Store
Thumbs.db

# Local configuration
*.local
config/*.local
```