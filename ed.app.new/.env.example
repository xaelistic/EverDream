# EverDream (ed.app.new) Environment Configuration
#
# QUICK SETUP (critical for making the app runnable):
#   cp .env.example .env
#   # Edit .env and replace all "your_*" / placeholder values with real ones.
#   npm run dev
#
# The app has graceful local-only / offline fallbacks for most features.
# Supabase is required for cloud sync, auth, dreams persistence, NFTs etc.
# Without it the app runs but data is browser-only (IndexedDB).
#
# Never commit .env, .env.local or real keys (already in .gitignore).
#
# AI / generation keys are optional but enable the full dream visualization,
# analysis, image gen v4, video, 3D assets etc.
#
# For server-side (Supabase Edge Functions like generate-image, analyze-dream):
#   Keys are set as Supabase secrets (see scripts/deploy-backend.sh or n8n flows),
#   NOT in this client .env.

# ============================================
# REQUIRED: Supabase (auth, DB, realtime, storage)
# Get from: Supabase Dashboard → Project Settings → API → Project URL + anon/public key
# ============================================
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# AI / IMAGE / VIDEO GENERATION (client-side or via edge)
# At least one recommended for full "visualize dream", image gen v4, video features.
# ============================================

# Primary / unified AI service token (used by some providers / pollinations / openrouter routing)
VITE_AI_SERVICE_TOKEN=your_ai_service_token_here

# OpenRouter (strong models for analysis + image prompts)
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Fal.ai (fast/cheap image gen)
VITE_FAL_AI_KEY=your_fal_ai_key_here

# Hugging Face Inference (Depth Anything v2 for depth maps in asset pipeline)
VITE_HF_INFERENCE_API_KEY=your_hf_inference_api_key_here

# Blockade Labs (skybox / 360° environments)
VITE_BLOCKADE_LABS_API_KEY=your_blockade_labs_api_key_here

# Meshy AI (text-to-3D meshes)
VITE_MESHY_API_KEY=your_meshy_api_key_here

# Tripo AI (alternative text-to-3D)
VITE_TRIPO_API_KEY=your_tripo_api_key_here

# Runway ML (image-to-video / motion)
VITE_RUNWAY_API_KEY=your_runway_api_key_here

# Replicate (alternative image/video models)
VITE_REPLICATE_API_TOKEN=your_replicate_api_token_here

# ============================================
# LOCAL / SELF-HOSTED GENERATION (optional)
# If you run Automatic1111 / ComfyUI / Fooocus / Stable Diffusion locally.
# ============================================
# VITE_LOCAL_GEN_URL=http://localhost:7860
# VITE_LOCAL_SD_URL=http://localhost:7860   # some components use this name
# VITE_ENABLE_LOCAL_GEN=true

# ============================================
# N8N / AUTOMATION WEBHOOKS (for overnight pipelines, batch asset gen, etc.)
# Used by DreamAssetGenerator, pipelines, and server orchestration.
# ============================================
VITE_N8N_WEBHOOK_URL=https://your-n8n-url.example.com/webhook
VITE_N8N_API_KEY=your_n8n_api_key_here

# Ollama local image generation (HSR-DeepThink/nwe) - Brief 1
# Dev mode (Windows host via Vite proxy):
VITE_OLLAMA_URL=/ollama
VITE_OLLAMA_ENABLED=true
# Production (Coolify → ngrok → Windows host):
# VITE_OLLAMA_URL=https://YOUR-NGROK-URL.ngrok-free.app
# VITE_OLLAMA_ENABLED=true

# ============================================
# NFT / IPFS / DISCORD / EXCHANGE
# ============================================
# Pinata JWT for IPFS metadata upload on mint
VITE_PINATA_JWT=your_pinata_jwt_here
# VITE_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# Simulated or real NFT contract (Base/Polygon testnet)
# VITE_NFT_CONTRACT_ADDRESS=0xYourContractAddress

# Discord webhook for mint/trade/simulacra notifications
VITE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_token

# Discord OAuth (future bot linking)
# VITE_DISCORD_CLIENT_ID=your_discord_app_client_id

# (Add any other provider keys your pipelines use as they are implemented.)