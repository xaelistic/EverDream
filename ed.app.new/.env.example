# EverDream Environment Variables
# Copy this to .env and fill in your values

# Supabase Configuration (required for cloud sync)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ===========================================
# AI PROVIDER KEYS (Server-side only via Supabase Secrets)
# ===========================================
# These are set on the server using: supabase secrets set KEY=value
# DO NOT expose these in client-side .env files!
#
# Provider Priority (free → cheap → open source):
# 1. OpenRouter (free models available) - https://openrouter.ai
# 2. Pollinations Text API (free, unlimited) - no key needed
# 3. Google Gemini 1.5 Flash (free tier) - https://aistudio.google.com
# 4. OpenAI GPT-4o-mini (cheap) - https://platform.openai.com
# 5. NVIDIA Nemotron (open source, cost-effective) - https://build.nvidia.com
#
# Set these via Supabase CLI:
#   supabase secrets set OPENROUTER_API_KEY=your_key
#   supabase secrets set GEMINI_API_KEY=your_key
#   supabase secrets set OPENAI_API_KEY=your_key
#   supabase secrets set NVIDIA_API_KEY=your_key

# Optional: HuggingFace Inference API key (for image generation fallback)
# VITE_HF_INFERENCE_API_KEY=hf_xxx

# ===========================================
# CHEAPEST IMAGE GENERATION OPTIONS
# ===========================================
# The app uses a tiered approach for dream image generation:
# 1. Supabase Edge Function (proxies Pollinations.ai) - FREE, no API key needed
# 2. Direct Pollinations.ai call - FREE, no API key needed  
# 3. Fal AI - Very cheap (~$0.001/image), very fast (get key at fal.ai)
# 4. Local Generation (ComfyUI/A1111) - Free if you run it locally
# 5. HuggingFace Inference API - FREE tier available
# 6. SVG placeholder fallback - Always works
#
# NO OpenAI/DALL-E keys required! The default setup uses completely free services.
# If you want higher quality/faster options, add one of these:
#
# Fal AI (~$0.001/image, fastest option):
# Get your key at https://fal.ai
VITE_FAL_AI_KEY=
#
# Local Stable Diffusion (Free, requires running on your machine):
# For A1111 (AUTOMATIC1111): http://localhost:7860
# For ComfyUI: http://localhost:8188
VITE_LOCAL_GEN_URL=http://localhost:7860
#
# OpenAI DALL-E 3 (~$0.04/image at 1024x1024):
# VITE_OPENAI_API_KEY=sk-...
#
# Stability AI Stable Diffusion XL (~$0.002-0.007/image):
# VITE_STABILITY_API_KEY=...
#
# Replicate SDXL (~$0.002/image):
# VITE_REPLICATE_API_TOKEN=...
