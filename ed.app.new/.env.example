# ============================================================
# EverDream — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── Optional: Direct API Keys (dev fallback only) ─────────────
# These are NOT needed if Supabase Edge Functions are deployed.
# The edge functions handle all AI providers server-side.
# VITE_ANTHROPIC_API_KEY=sk-ant-xxx
# VITE_HF_INFERENCE_API_KEY=hf_xxx
