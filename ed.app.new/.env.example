# EverDream Environment Variables
# Copy this file to .env and fill in your values

# Supabase Configuration (REQUIRED)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Anthropic API Key (optional, for direct API fallback during development)
# In production, use Supabase Edge Functions with secrets instead
VITE_ANTHROPIC_API_KEY=

# HuggingFace API Key (optional, for Whisper transcription fallback)
VITE_HF_API_KEY=

# OpenRouter API Key (optional, for edge function multi-provider fallback)
# Set via: supabase secrets set OPENROUTER_API_KEY=sk-or-xxx
