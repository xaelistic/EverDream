# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Hugging Face API Token (FREE - get from hf.co/settings/tokens)
# Required for AI image generation via Hugging Face Inference API
VITE_HUGGINGFACE_TOKEN=hf_your_token_here

# Optional: Local Generation (if running Stable Diffusion locally)
# VITE_LOCAL_GEN_URL=http://localhost:7860
# VITE_ENABLE_LOCAL_GEN=true
